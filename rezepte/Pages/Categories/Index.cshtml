@page
@model rezepte.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Kategorien";
}

<div class="hero">
    <div class="container">
        <h1>🏷️ Kategorien</h1>
        <p class="mb-0 opacity-75">Verwalte deine Rezept-Kategorien</p>
    </div>
</div>

<div class="container" style="max-width: 600px;">

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger rounded-3">@Model.ErrorMessage</div>
    }
    @if (Model.SuccessMessage != null)
    {
        <div class="alert alert-success rounded-3">✅ @Model.SuccessMessage</div>
    }

    <!-- Neue Kategorie -->
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="fw-bold mb-3">Neue Kategorie erstellen</h5>
            <form method="post" asp-page-handler="Add">
                <div class="input-group">
                    <input asp-for="NewCategoryColor" type="color" class="form-control form-control-color"
                           style="max-width:50px;" title="Farbe wählen" />
                    <input asp-for="NewCategoryName" class="form-control"
                           placeholder="z.B. Mexikanisch, Frühstück, Grillen..." />
                    <button type="submit" class="btn btn-success px-4">+ Hinzufügen</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Bestehende Kategorien -->
    <div class="card">
        <div class="card-body">
            <h5 class="fw-bold mb-3">Alle Kategorien (@Model.Categories.Count)</h5>

            @if (!Model.Categories.Any())
            {
                <p class="text-muted">Noch keine Kategorien vorhanden.</p>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var category in Model.Categories)
                    {
                        <li class="list-group-item px-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge fs-6" style="background-color: @category.Color;">@category.Name</span>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-secondary"
                                            onclick="toggleEdit(@category.Id)">✏️</button>
                                    <form method="post" asp-page-handler="Delete"
                                          onsubmit="return confirm('Kategorie @category.Name wirklich löschen?')">
                                        <input type="hidden" name="id" value="@category.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">🗑️</button>
                                    </form>
                                </div>
                            </div>

                            <!-- Inline-Bearbeiten-Formular (standardmäßig versteckt) -->
                            <form method="post" asp-page-handler="Edit"
                                  id="edit-form-@category.Id" class="mt-2" style="display:none;">
                                <input type="hidden" name="EditCategoryId" value="@category.Id" />
                                <div class="input-group">
                                    <input type="color" name="EditCategoryColor"
                                           value="@category.Color"
                                           class="form-control form-control-color" style="max-width:50px;" />
                                    <input type="text" name="EditCategoryName"
                                           value="@category.Name"
                                           class="form-control" />
                                    <button type="submit" class="btn btn-success btn-sm">Speichern</button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                            onclick="toggleEdit(@category.Id)">Abbrechen</button>
                                </div>
                            </form>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-page="/Index" class="btn btn-outline-secondary">← Zurück zu Rezepten</a>
    </div>
</div>

@section Scripts {
    <script>
        function toggleEdit(id) {
            var form = document.getElementById('edit-form-' + id);
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
        }
    </script>
}
