@page
@model rezepte.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Kategorien";
}

<div class="page-hero">
    <div class="container">
        <h1><i data-lucide="tag" style="width:32px; height:32px; display:inline; vertical-align:middle; margin-right:8px;"></i>Kategorien</h1>
        <p class="mb-0">Verwalte deine Rezept-Kategorien</p>
    </div>
</div>

<div class="container" style="max-width: 600px;">

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger rounded-3 d-flex align-items-center gap-2">
            <i data-lucide="alert-circle" style="width:18px; height:18px; flex-shrink:0;"></i>
            @Model.ErrorMessage
        </div>
    }
    @if (Model.SuccessMessage != null)
    {
        <div class="alert alert-success rounded-3 d-flex align-items-center gap-2">
            <i data-lucide="check-circle" style="width:18px; height:18px; flex-shrink:0;"></i>
            @Model.SuccessMessage
        </div>
    }

    <!-- Neue Kategorie -->
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="fw-bold mb-3">Neue Kategorie erstellen</h5>
            <form method="post" asp-page-handler="Add">
                <div class="input-group">
                    <input asp-for="NewCategoryColor" type="color" class="form-control form-control-color"
                           style="max-width:50px;" title="Farbe wählen" aria-label="Kategorie-Farbe wählen" />
                    <input asp-for="NewCategoryName" class="form-control"
                           placeholder="z.B. Mexikanisch, Frühstück, Grillen..." aria-label="Kategorie-Name" />
                    <button type="submit" class="btn btn-success px-4">
                        <i data-lucide="plus" style="width:16px; height:16px;"></i> Hinzufügen
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Bestehende Kategorien -->
    <div class="card">
        <div class="card-body">
            <h5 class="fw-bold mb-3">Alle Kategorien (@Model.Categories.Count)</h5>

            @if (!Model.Categories.Any())
            {
                <p class="text-muted">Noch keine Kategorien vorhanden.</p>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var category in Model.Categories)
                    {
                        <li class="list-group-item px-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge fs-6" style="background-color: @category.Color;">@category.Name</span>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-secondary"
                                            onclick="toggleEdit(@category.Id)" aria-label="@category.Name bearbeiten">
                                        <i data-lucide="pencil" style="width:14px; height:14px;"></i>
                                    </button>
                                    <form method="post" asp-page-handler="Delete"
                                          onsubmit="return confirm('Kategorie @category.Name wirklich löschen?')">
                                        <input type="hidden" name="id" value="@category.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                aria-label="@category.Name löschen">
                                            <i data-lucide="trash-2" style="width:14px; height:14px;"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>

                            <!-- Inline-Bearbeiten -->
                            <form method="post" asp-page-handler="Edit"
                                  id="edit-form-@category.Id" class="mt-2" style="display:none;">
                                <input type="hidden" name="EditCategoryId" value="@category.Id" />
                                <div class="input-group">
                                    <input type="color" name="EditCategoryColor"
                                           value="@category.Color"
                                           class="form-control form-control-color" style="max-width:50px;"
                                           aria-label="Farbe ändern" />
                                    <input type="text" name="EditCategoryName"
                                           value="@category.Name"
                                           class="form-control" aria-label="Name ändern" />
                                    <button type="submit" class="btn btn-success btn-sm">Speichern</button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                            onclick="toggleEdit(@category.Id)">Abbrechen</button>
                                </div>
                            </form>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-page="/Index" class="btn-outline-ink">
            <i data-lucide="arrow-left" style="width:14px; height:14px;"></i> Zurück zu Rezepten
        </a>
    </div>
</div>

@section Scripts {
    <script>
        function toggleEdit(id) {
            var form = document.getElementById('edit-form-' + id);
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
        }
    </script>
}
