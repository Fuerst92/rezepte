@page "{id:int}"
@model rezepte.Pages.Recipes.DetailModel
@{
    ViewData["Title"] = Model.Recipe.Title;
    var ingredients = Model.Recipe.Ingredients
        .Split('\n', StringSplitOptions.RemoveEmptyEntries)
        .Select(i => i.Trim())
        .ToList();
    var steps = Model.Recipe.Steps
        .Split('\n', StringSplitOptions.RemoveEmptyEntries)
        .Select(s => s.Trim())
        .ToList();
    var equipmentList = string.IsNullOrWhiteSpace(Model.Recipe.Equipment)
        ? new List<string>()
        : Model.Recipe.Equipment
            .Split('\n', StringSplitOptions.RemoveEmptyEntries)
            .Select(e => e.Trim())
            .ToList();
}

<style>
    .recipe-card {
        max-width: 780px;
        margin: 40px auto;
        background: #fff;
        border: 1px solid #e0ddd8;
        border-radius: 4px;
        overflow: hidden;
        box-shadow: 0 2px 20px rgba(0,0,0,0.08);
    }

    .recipe-hero {
        width: 100%;
        height: 320px;
        object-fit: cover;
        display: block;
    }

    .recipe-hero-placeholder {
        width: 100%;
        height: 320px;
        background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #c8c0b4;
    }

    .recipe-body {
        padding: 40px 48px 32px;
    }

    .recipe-title {
        font-family: 'Dancing Script', cursive;
        font-size: 3rem;
        text-align: center;
        color: #1c1c1c;
        margin-bottom: 8px;
        line-height: 1.2;
    }

    .recipe-description {
        text-align: center;
        color: #6b7280;
        font-size: 0.95rem;
        margin-bottom: 32px;
    }

    .section-header {
        text-align: center;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: #374151;
        margin-bottom: 20px;
        position: relative;
    }

    .section-header::before,
    .section-header::after {
        content: '';
        position: absolute;
        top: 50%;
        width: 60px;
        height: 1px;
        background: #d1d5db;
    }

    .section-header::before { right: calc(50% + 80px); }
    .section-header::after  { left:  calc(50% + 80px); }

    .ingredients-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 6px 24px;
        margin-bottom: 36px;
        font-size: 0.9rem;
        color: #374151;
    }

    .ingredients-grid span {
        padding: 4px 0;
        border-bottom: 1px solid #f3f4f6;
    }

    .steps-list {
        list-style: none;
        padding: 0;
        margin-bottom: 32px;
    }

    .steps-list li {
        display: flex;
        gap: 16px;
        margin-bottom: 16px;
        font-size: 0.9rem;
        color: #374151;
        line-height: 1.7;
        text-align: justify;
    }

    .step-number {
        font-weight: 700;
        color: #1a1a1a;
        min-width: 20px;
        padding-top: 1px;
    }

    .recipe-divider {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 28px 0;
    }

    .recipe-meta {
        display: flex;
        justify-content: center;
        gap: 40px;
        font-size: 0.875rem;
        color: #6b7280;
        flex-wrap: wrap;
    }

    .recipe-meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .recipe-meta-item .icon {
        width: 16px;
        height: 16px;
        stroke-width: 2;
        color: var(--muted);
    }

    .recipe-actions {
        max-width: 780px;
        margin: 0 auto 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0 4px;
        flex-wrap: wrap;
    }

    .recipe-actions .btn {
        min-height: 38px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .recipe-actions .btn .icon {
        width: 14px;
        height: 14px;
        stroke-width: 2;
    }

    .portions-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 24px;
        font-size: 0.9rem;
        color: #374151;
    }

    .portions-label {
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .portions-label .icon {
        width: 18px;
        height: 18px;
        stroke-width: 2;
    }

    .portions-btn {
        width: 44px;
        height: 44px;
        border: 1px solid #d1d5db;
        border-radius: 50%;
        background: #fff;
        font-size: 1.1rem;
        line-height: 1;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s ease, border-color 0.15s ease;
    }

    .portions-btn:hover {
        background: #f3f4f6;
        border-color: var(--ink);
    }

    .portions-btn:active {
        transform: scale(0.95);
    }

    #portions-input {
        width: 56px;
        text-align: center;
        border: 1px solid #d1d5db;
        border-radius: 4px;
        padding: 3px 6px;
        font-size: 0.95rem;
    }

    .equipment-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px 24px;
        margin-bottom: 36px;
    }

    .equipment-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        color: #374151;
        padding: 4px 0;
        border-bottom: 1px solid #f3f4f6;
    }

    .equipment-item .icon {
        width: 16px;
        height: 16px;
        stroke-width: 2;
        color: var(--muted);
        flex-shrink: 0;
    }

    @@media print {
        .site-header,
        .site-footer,
        .recipe-actions,
        .portions-bar { display: none !important; }

        body { background: white !important; }
        .recipe-card {
            box-shadow: none !important;
            border: none !important;
            max-width: 100% !important;
            margin: 0 !important;
        }

        .recipe-hero { height: 200px !important; }
    }

    @@media (prefers-reduced-motion: reduce) {
        .portions-btn:active { transform: none; }
    }
</style>

<div class="container-fluid px-3">

    <!-- Aktions-Leiste -->
    <div class="recipe-actions">
        <a asp-page="/Index" class="btn btn-sm btn-outline-secondary">
            <i data-lucide="arrow-left" class="icon"></i> Zurück
        </a>
        <a asp-page="/Recipes/Edit" asp-route-id="@Model.Recipe.Id" class="btn btn-sm btn-outline-secondary">
            <i data-lucide="pencil" class="icon"></i> Bearbeiten
        </a>

        <form method="post" asp-page-handler="ToggleFavorite" class="mb-0">
            <input type="hidden" name="id" value="@Model.Recipe.Id" />
            <button class="btn btn-sm @(Model.Recipe.IsFavorite ? "btn-warning" : "btn-outline-warning")"
                    aria-label="@(Model.Recipe.IsFavorite ? "Von Favoriten entfernen" : "Zu Favoriten hinzufügen")">
                <i data-lucide="crown" class="icon"></i> Favorit
            </button>
        </form>

        <button onclick="window.print()" class="btn btn-sm btn-outline-secondary" aria-label="Rezept drucken">
            <i data-lucide="printer" class="icon"></i> Drucken
        </button>

        <form method="post" asp-page-handler="Delete" class="mb-0 ms-auto"
              onsubmit="return confirm('Rezept wirklich löschen?')">
            <input type="hidden" name="id" value="@Model.Recipe.Id" />
            <button class="btn btn-sm btn-outline-danger" aria-label="Rezept löschen">
                <i data-lucide="trash-2" class="icon"></i> Löschen
            </button>
        </form>
    </div>

    <!-- Rezept-Karte -->
    <div class="recipe-card">

        @if (!string.IsNullOrEmpty(Model.Recipe.ImageUrl))
        {
            <img src="@Model.Recipe.ImageUrl" class="recipe-hero" alt="@Model.Recipe.Title" loading="eager">
        }
        else
        {
            <div class="recipe-hero-placeholder">
                <i data-lucide="utensils-crossed" style="width:64px; height:64px; stroke-width:1;"></i>
            </div>
        }

        <div class="recipe-body">

            <h1 class="recipe-title">@Model.Recipe.Title</h1>
            @if (!string.IsNullOrEmpty(Model.Recipe.Description))
            {
                <p class="recipe-description">@Model.Recipe.Description</p>
            }

            <hr class="recipe-divider">

            <!-- Portionsrechner -->
            <div class="portions-bar">
                <span class="portions-label">
                    <i data-lucide="cooking-pot" class="icon"></i> Portionen:
                </span>
                <button class="portions-btn" onclick="changePortions(-1)" aria-label="Portion verringern">−</button>
                <input type="number" id="portions-input" value="@Model.Recipe.Servings"
                       min="1" max="100" oninput="updateIngredients()" aria-label="Anzahl Portionen" />
                <button class="portions-btn" onclick="changePortions(1)" aria-label="Portion erhöhen">+</button>
            </div>

            <h2 class="section-header">Zutaten</h2>
            <div class="ingredients-grid" id="ingredients-grid">
                @foreach (var ingredient in ingredients)
                {
                    <span data-original="@ingredient">@ingredient</span>
                }
            </div>

            <hr class="recipe-divider">

            <h2 class="section-header">Zubereitung</h2>
            <ol class="steps-list">
                @for (int i = 0; i < steps.Count; i++)
                {
                    <li>
                        <span class="step-number">@(i + 1).</span>
                        <span>@steps[i]</span>
                    </li>
                }
            </ol>

            @if (equipmentList.Any())
            {
                <hr class="recipe-divider">
                <h2 class="section-header">Benötigte Utensilien</h2>
                <div class="equipment-grid">
                    @foreach (var item in equipmentList)
                    {
                        <div class="equipment-item">
                            <i data-lucide="chef-hat" class="icon"></i>
                            <span>@item</span>
                        </div>
                    }
                </div>
            }

            <hr class="recipe-divider">
            <div class="recipe-meta">
                @foreach (var cat in Model.Recipe.Categories)
                {
                    <div class="recipe-meta-item">
                        <i data-lucide="tag" class="icon"></i>
                        <span style="color:@cat.Color;">@cat.Name</span>
                    </div>
                }
                <div class="recipe-meta-item">
                    <i data-lucide="calendar" class="icon"></i>
                    <span>@Model.Recipe.CreatedAt.ToString("dd. MMMM yyyy")</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Recipe.VideoUrl))
                {
                    <div class="recipe-meta-item">
                        <a href="@Model.Recipe.VideoUrl" target="_blank" rel="noopener" class="text-danger text-decoration-none d-flex align-items-center gap-1">
                            <i data-lucide="play-circle" class="icon"></i> Video ansehen
                        </a>
                    </div>
                }
            </div>

        </div>
    </div>
</div>

<script>
    const basePortions = @Model.Recipe.Servings;

    function changePortions(delta) {
        const input = document.getElementById('portions-input');
        const newVal = Math.max(1, (parseInt(input.value) || basePortions) + delta);
        input.value = newVal;
        updateIngredients();
    }

    function updateIngredients() {
        const input = document.getElementById('portions-input');
        const newPortions = Math.max(1, parseInt(input.value) || basePortions);
        const factor = newPortions / basePortions;

        document.querySelectorAll('#ingredients-grid span').forEach(span => {
            const original = span.getAttribute('data-original');
            span.textContent = scaleIngredient(original, factor);
        });
    }

    function scaleIngredient(text, factor) {
        return text.replace(/\d+([.,]\d+)?/g, match => {
            const num = parseFloat(match.replace(',', '.')) * factor;
            if (num % 1 === 0) return Math.round(num).toString();
            return (Math.round(num * 10) / 10).toString().replace('.', ',');
        });
    }
</script>
