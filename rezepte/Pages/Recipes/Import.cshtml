@page
@model rezepte.Pages.Recipes.ImportModel
@{
    ViewData["Title"] = "Rezept importieren";
}

<div class="container mt-4" style="max-width: 750px;">

    <h1 class="mb-1" style="font-family:'Playfair Display',serif;">Rezept importieren</h1>
    <p style="color:var(--muted);" class="mb-4">Importiere ein Rezept aus YouTube, Instagram oder TikTok.</p>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2">
            <i data-lucide="alert-circle" style="width:18px; height:18px; flex-shrink:0;"></i>
            @Model.ErrorMessage
        </div>
    }

    <!-- Tabs -->
    <ul class="nav mb-4" style="border-bottom: 2px solid var(--border); gap:0; list-style:none; padding:0; display:flex;" role="tablist">
        <li role="presentation">
            <a href="#" onclick="switchTab('youtube'); return false;" id="tab-youtube" role="tab"
               aria-selected="@(Model.ActiveTab == "youtube" ? "true" : "false")"
               class="tab-btn @(Model.ActiveTab == "youtube" ? "tab-active" : "")">
                <i data-lucide="play" style="width:14px; height:14px;"></i> YouTube
            </a>
        </li>
        <li role="presentation">
            <a href="#" onclick="switchTab('social'); return false;" id="tab-social" role="tab"
               aria-selected="@(Model.ActiveTab == "social" ? "true" : "false")"
               class="tab-btn @(Model.ActiveTab == "social" ? "tab-active" : "")">
                <i data-lucide="smartphone" style="width:14px; height:14px;"></i> Instagram / TikTok
            </a>
        </li>
    </ul>

    <style>
        .tab-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 12px 24px;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            text-decoration: none;
            color: var(--muted);
            border-bottom: 3px solid transparent;
            margin-bottom: -2px;
            transition: color 0.2s ease, border-color 0.2s ease;
            min-height: 44px;
        }
        .tab-btn:hover { color: var(--ink); }
        .tab-active { color: var(--ink) !important; border-bottom-color: var(--accent) !important; }
        .tab-panel { display: none; }
        .tab-panel.show { display: block; }
    </style>

    <!-- YouTube Tab -->
    <div id="panel-youtube" class="tab-panel @(Model.ActiveTab == "youtube" ? "show" : "")" role="tabpanel">

        <div class="card mb-4" style="border:1px solid var(--border); border-radius:8px;">
            <div class="card-body p-4">
                <form method="post" asp-page-handler="Analyze" id="ytForm">
                    <label class="form-label fw-bold" style="font-size:0.85rem; letter-spacing:1px; text-transform:uppercase;">YouTube-Link</label>
                    <div class="input-group">
                        <input name="YoutubeUrl" value="@Model.YoutubeUrl" class="form-control"
                               placeholder="https://www.youtube.com/watch?v=..." aria-label="YouTube URL eingeben" />
                        <button type="submit" id="ytBtn" class="btn-accent" style="white-space:nowrap;">
                            Analysieren
                        </button>
                    </div>
                </form>
                <div id="ytLoading" class="mt-3 d-none" role="status">
                    <div class="d-flex align-items-center gap-2" style="color:var(--muted);">
                        <div class="spinner-border spinner-border-sm" style="color:var(--accent);" aria-hidden="true"></div>
                        <span style="font-size:0.875rem;">KI analysiert das Video... ca. 10–20 Sekunden.</span>
                    </div>
                    <div class="progress mt-2" style="height:3px; border-radius:0;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated w-100" style="background:var(--accent);"></div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.RecipeLoaded && Model.ActiveTab == "youtube")
        {
            <div class="alert d-flex align-items-center gap-2" style="background:#f0faf4; border:1px solid #a3d9b1; color:#2d6a4f;">
                <i data-lucide="check-circle" style="width:18px; height:18px; flex-shrink:0;"></i>
                KI hat das Rezept extrahiert! Bitte prüfen und ggf. korrigieren.
            </div>

            @if (Model.VideoId != null)
            {
                <div class="ratio ratio-16x9 mb-4">
                    <iframe src="https://www.youtube.com/embed/@Model.VideoId" allowfullscreen title="YouTube Video"></iframe>
                </div>
            }

            <form method="post" asp-page-handler="Save">
                <input type="hidden" name="YoutubeUrl" value="@Model.YoutubeUrl" />
                <div class="mb-3">
                    <label asp-for="Recipe.Title" class="form-label fw-bold"></label>
                    <input asp-for="Recipe.Title" class="form-control" />
                    <span asp-validation-for="Recipe.Title" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label class="form-label fw-bold mb-0">Kategorien</label>
                        <a asp-page="/Categories/Index" style="font-size:0.8rem; color:var(--accent);">+ Neue Kategorie erstellen</a>
                    </div>
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var cat in Model.AllCategories)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       name="SelectedCategoryIds" value="@cat.Id" id="ycat_@cat.Id" />
                                <label class="form-check-label" for="ycat_@cat.Id"
                                       style="color:@cat.Color; font-weight:600;">@cat.Name</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Recipe.Description" class="form-label fw-bold"></label>
                    <textarea asp-for="Recipe.Description" class="form-control" rows="2"></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="Recipe.Ingredients" class="form-label fw-bold"></label>
                    <textarea asp-for="Recipe.Ingredients" class="form-control" rows="6"></textarea>
                    <div class="form-text">Eine Zutat pro Zeile</div>
                </div>
                <div class="mb-3">
                    <label asp-for="Recipe.Steps" class="form-label fw-bold"></label>
                    <textarea asp-for="Recipe.Steps" class="form-control" rows="8"></textarea>
                    <div class="form-text">Einen Schritt pro Zeile</div>
                </div>
                <div class="mb-3">
                    <label asp-for="Recipe.Equipment" class="form-label fw-bold"></label>
                    <textarea asp-for="Recipe.Equipment" class="form-control" rows="4"></textarea>
                    <div class="form-text">Ein Gerät / Utensil pro Zeile</div>
                </div>
                <div class="mb-3">
                    <label asp-for="Recipe.Servings" class="form-label fw-bold"></label>
                    <input asp-for="Recipe.Servings" class="form-control" type="number" min="1" max="100" />
                </div>
                <div class="mb-3">
                    <label asp-for="Recipe.ImageUrl" class="form-label fw-bold">Vorschaubild-URL</label>
                    <input asp-for="Recipe.ImageUrl" class="form-control" />
                </div>
                <input type="hidden" asp-for="Recipe.VideoUrl" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-accent py-2 px-4">
                        <i data-lucide="save" style="width:16px; height:16px;"></i> Rezept speichern
                    </button>
                    <a asp-page="/Index" class="btn-outline-ink py-2">Abbrechen</a>
                </div>
            </form>
        }
    </div>

    <!-- Instagram / TikTok Tab -->
    <div id="panel-social" class="tab-panel @(Model.ActiveTab == "social" ? "show" : "")" role="tabpanel">

        <div class="card mb-4" style="border:1px solid var(--border); border-radius:8px;">
            <div class="card-body p-4">

                <div class="mb-4 p-3 d-flex gap-2" style="background:#fdf6ec; border:1px solid #f0d9b0; color:#7a5c2e; font-size:0.875rem; border-radius:6px;">
                    <i data-lucide="info" style="width:18px; height:18px; flex-shrink:0; margin-top:2px;"></i>
                    <div>
                        <strong>So geht's:</strong><br>
                        1. Öffne den Post auf Instagram oder TikTok<br>
                        2. Tippe auf <strong>„..."</strong> → <strong>„Link kopieren"</strong> → unten einfügen (optional)<br>
                        3. Kopiere die <strong>Caption</strong> komplett → ins Textfeld einfügen<br>
                        4. Klick auf <strong>„Rezept extrahieren"</strong>
                    </div>
                </div>

                <form method="post" asp-page-handler="AnalyzeSocial" id="socialForm">
                    <div class="mb-3">
                        <label class="form-label fw-bold" style="font-size:0.85rem; letter-spacing:1px; text-transform:uppercase;">
                            Post-Link <span style="font-weight:400; color:var(--muted);">(optional)</span>
                        </label>
                        <input name="SocialUrl" value="@Model.SocialUrl" class="form-control"
                               placeholder="https://www.instagram.com/p/... oder https://www.tiktok.com/@@..."
                               aria-label="Social Media URL" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold" style="font-size:0.85rem; letter-spacing:1px; text-transform:uppercase;">
                            Caption / Text des Posts <span style="color:var(--danger);">*</span>
                        </label>
                        <textarea name="SocialCaption" class="form-control" rows="8"
                                  placeholder="Füge hier den Text des Posts ein..."
                                  aria-label="Post-Text einfügen" required>@Model.SocialCaption</textarea>
                        <div class="form-text">Den Text einfach komplett reinkopieren – die KI findet das Rezept darin.</div>
                    </div>
                    <button type="submit" id="socialBtn" class="btn-accent">
                        <i data-lucide="sparkles" style="width:16px; height:16px;"></i> Rezept extrahieren
                    </button>
                </form>

                <div id="socialLoading" class="mt-3 d-none" role="status">
                    <div class="d-flex align-items-center gap-2" style="color:var(--muted);">
                        <div class="spinner-border spinner-border-sm" style="color:var(--accent);" aria-hidden="true"></div>
                        <span style="font-size:0.875rem;">KI liest den Text... ca. 5–10 Sekunden.</span>
                    </div>
                    <div class="progress mt-2" style="height:3px; border-radius:0;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated w-100" style="background:var(--accent);"></div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.RecipeLoaded && Model.ActiveTab == "social")
        {
            <div class="alert d-flex align-items-center gap-2" style="background:#f0faf4; border:1px solid #a3d9b1; color:#2d6a4f;">
                <i data-lucide="check-circle" style="width:18px; height:18px; flex-shrink:0;"></i>
                KI hat das Rezept extrahiert! Bitte prüfen und ggf. korrigieren.
            </div>

            <form method="post" asp-page-handler="Save">
                <input type="hidden" name="SocialUrl" value="@Model.SocialUrl" />
                <div class="mb-3">
                    <label asp-for="Recipe.Title" class="form-label fw-bold"></label>
                    <input asp-for="Recipe.Title" class="form-control" />
                    <span asp-validation-for="Recipe.Title" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label class="form-label fw-bold mb-0">Kategorien</label>
                        <a asp-page="/Categories/Index" style="font-size:0.8rem; color:var(--accent);">+ Neue Kategorie erstellen</a>
                    </div>
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var cat in Model.AllCategories)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       name="SelectedCategoryIds" value="@cat.Id" id="scat_@cat.Id" />
                                <label class="form-check-label" for="scat_@cat.Id"
                                       style="color:@cat.Color; font-weight:600;">@cat.Name</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Recipe.Description" class="form-label fw-bold"></label>
                    <textarea asp-for="Recipe.Description" class="form-control" rows="2"></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="Recipe.Ingredients" class="form-label fw-bold"></label>
                    <textarea asp-for="Recipe.Ingredients" class="form-control" rows="6"></textarea>
                    <div class="form-text">Eine Zutat pro Zeile</div>
                </div>
                <div class="mb-3">
                    <label asp-for="Recipe.Steps" class="form-label fw-bold"></label>
                    <textarea asp-for="Recipe.Steps" class="form-control" rows="8"></textarea>
                    <div class="form-text">Einen Schritt pro Zeile</div>
                </div>
                <div class="mb-3">
                    <label asp-for="Recipe.ImageUrl" class="form-label fw-bold">Bild-URL (optional)</label>
                    <input asp-for="Recipe.ImageUrl" class="form-control"
                           placeholder="https://... Screenshot-URL oder leer lassen" />
                </div>
                <input type="hidden" asp-for="Recipe.VideoUrl" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-accent py-2 px-4">
                        <i data-lucide="save" style="width:16px; height:16px;"></i> Rezept speichern
                    </button>
                    <a asp-page="/Index" class="btn-outline-ink py-2">Abbrechen</a>
                </div>
            </form>
        }
    </div>

</div>

@section Scripts {
<script>
    function switchTab(tab) {
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('show'));
        document.querySelectorAll('.tab-btn').forEach(b => {
            b.classList.remove('tab-active');
            b.setAttribute('aria-selected', 'false');
        });
        document.getElementById('panel-' + tab).classList.add('show');
        const activeTab = document.getElementById('tab-' + tab);
        activeTab.classList.add('tab-active');
        activeTab.setAttribute('aria-selected', 'true');
    }

    document.getElementById('ytForm').addEventListener('submit', function () {
        document.getElementById('ytLoading').classList.remove('d-none');
        const btn = document.getElementById('ytBtn');
        btn.disabled = true;
        btn.textContent = 'Analysiere...';
    });

    document.getElementById('socialForm').addEventListener('submit', function () {
        document.getElementById('socialLoading').classList.remove('d-none');
        const btn = document.getElementById('socialBtn');
        btn.disabled = true;
        btn.textContent = 'KI arbeitet...';
    });
</script>
}
