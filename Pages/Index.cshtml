@page
@model rezepte.Pages.IndexModel
@{
    ViewData["Title"] = "Alle Rezepte";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Rezepte</h1>
        <a asp-page="/Recipes/Create" class="btn btn-success">+ Neues Rezept</a>
    </div>

    <div class="mb-4 d-flex flex-wrap gap-1">
        <a asp-page="/Index" class="btn btn-sm @(Model.SelectedCategoryId == null && !Model.FavoritesOnly ? "btn-primary" : "btn-outline-primary")">
            Alle
        </a>
        <a asp-page="/Index" asp-route-favoritesOnly="true"
           class="btn btn-sm @(Model.FavoritesOnly ? "btn-warning" : "btn-outline-warning")">
            ⭐ Favoriten
        </a>
        @foreach (var category in Model.Categories)
        {
            <a asp-page="/Index" asp-route-selectedCategoryId="@category.Id"
               class="btn btn-sm @(Model.SelectedCategoryId == category.Id ? "btn-secondary" : "btn-outline-secondary")">
                @category.Name
            </a>
        }
    </div>

    @if (!Model.Recipes.Any())
    {
        <div class="alert alert-info">Keine Rezepte gefunden. <a asp-page="/Recipes/Create">Jetzt eins erstellen!</a></div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var recipe in Model.Recipes)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(recipe.ImageUrl))
                        {
                            <img src="@recipe.ImageUrl" class="card-img-top" alt="@recipe.Title"
                                 style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center"
                                 style="height: 200px;">
                                <span class="text-muted fs-1">🍴</span>
                            </div>
                        }

                        <div class="card-body">
                            <span class="badge bg-secondary mb-1">@recipe.Category.Name</span>
                            <h5 class="card-title">@recipe.Title</h5>
                            <p class="card-text text-muted small">@recipe.Description</p>
                        </div>

                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <a asp-page="/Recipes/Detail" asp-route-id="@recipe.Id"
                               class="btn btn-sm btn-primary">Ansehen</a>

                            <form method="post" asp-page-handler="ToggleFavorite">
                                <input type="hidden" name="id" value="@recipe.Id" />
                                <input type="hidden" name="SelectedCategoryId" value="@Model.SelectedCategoryId" />
                                <input type="hidden" name="FavoritesOnly" value="@Model.FavoritesOnly" />
                                <button type="submit" class="btn btn-sm @(recipe.IsFavorite ? "btn-warning" : "btn-outline-warning")">
                                    @(recipe.IsFavorite ? "⭐ Favorit" : "☆ Favorit")
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
