@page
@model rezepte.Pages.Recipes.CreateModel
@{
    ViewData["Title"] = "Neues Rezept";
}

<!-- Hero -->
<div class="page-hero">
    <div class="container">
        <span class="label" style="font-size:0.7rem; letter-spacing:3px; text-transform:uppercase;
                                   color:var(--muted); display:block; margin-bottom:8px;">Rezepte</span>
        <h1>Neues Rezept erstellen</h1>
    </div>
</div>

<div class="container" style="max-width:700px; padding-bottom:80px;">

    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <form method="post">

        <div class="mb-4">
            <label asp-for="Recipe.Title"
                   style="display:block; font-size:0.75rem; letter-spacing:1.5px;
                          text-transform:uppercase; font-weight:700; color:var(--ink); margin-bottom:6px;"></label>
            <input asp-for="Recipe.Title" class="form-control" placeholder="z.B. Spaghetti Bolognese" />
            <span asp-validation-for="Recipe.Title" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Recipe.CategoryId"
                   style="display:block; font-size:0.75rem; letter-spacing:1.5px;
                          text-transform:uppercase; font-weight:700; color:var(--ink); margin-bottom:6px;">
                Kategorie
            </label>
            <select asp-for="Recipe.CategoryId" asp-items="Model.CategoryOptions" class="form-select">
                <option value="">— Kategorie wählen —</option>
            </select>
            <span asp-validation-for="Recipe.CategoryId" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Recipe.Description"
                   style="display:block; font-size:0.75rem; letter-spacing:1.5px;
                          text-transform:uppercase; font-weight:700; color:var(--ink); margin-bottom:6px;"></label>
            <textarea asp-for="Recipe.Description" class="form-control" rows="2"
                      placeholder="Kurze Beschreibung des Rezepts"></textarea>
        </div>

        <div class="section-divider" style="margin:32px 0 24px;"><span>Rezept</span></div>

        <div class="mb-4">
            <label asp-for="Recipe.Ingredients"
                   style="display:block; font-size:0.75rem; letter-spacing:1.5px;
                          text-transform:uppercase; font-weight:700; color:var(--ink); margin-bottom:6px;"></label>
            <textarea asp-for="Recipe.Ingredients" class="form-control" rows="6"
                      placeholder="Eine Zutat pro Zeile:&#10;200g Mehl&#10;3 Eier&#10;100ml Milch"></textarea>
            <div style="font-size:0.8rem; color:var(--muted); margin-top:4px;">Eine Zutat pro Zeile eingeben</div>
            <span asp-validation-for="Recipe.Ingredients" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Recipe.Steps"
                   style="display:block; font-size:0.75rem; letter-spacing:1.5px;
                          text-transform:uppercase; font-weight:700; color:var(--ink); margin-bottom:6px;"></label>
            <textarea asp-for="Recipe.Steps" class="form-control" rows="8"
                      placeholder="Einen Schritt pro Zeile:&#10;Zwiebeln würfeln und anbraten&#10;Hackfleisch hinzufügen"></textarea>
            <div style="font-size:0.8rem; color:var(--muted); margin-top:4px;">Einen Schritt pro Zeile (Nummerierung nicht nötig)</div>
            <span asp-validation-for="Recipe.Steps" class="text-danger small"></span>
        </div>

        <div class="section-divider" style="margin:32px 0 24px;"><span>Optional</span></div>

        <div class="mb-4">
            <label asp-for="Recipe.ImageUrl"
                   style="display:block; font-size:0.75rem; letter-spacing:1.5px;
                          text-transform:uppercase; font-weight:700; color:var(--ink); margin-bottom:6px;"></label>
            <input asp-for="Recipe.ImageUrl" class="form-control"
                   placeholder="https://beispiel.com/bild.jpg" />
            <div style="font-size:0.8rem; color:var(--muted); margin-top:4px;">Link zu einem Bild im Internet</div>
            <span asp-validation-for="Recipe.ImageUrl" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Recipe.VideoUrl"
                   style="display:block; font-size:0.75rem; letter-spacing:1.5px;
                          text-transform:uppercase; font-weight:700; color:var(--ink); margin-bottom:6px;"></label>
            <input asp-for="Recipe.VideoUrl" class="form-control"
                   placeholder="https://youtube.com/watch?v=..." />
            <div style="font-size:0.8rem; color:var(--muted); margin-top:4px;">YouTube-Link</div>
            <span asp-validation-for="Recipe.VideoUrl" class="text-danger small"></span>
        </div>

        <div style="display:flex; gap:12px; padding-top:8px;">
            <button type="submit" class="btn-accent">Rezept speichern</button>
            <a asp-page="/Index" class="btn-outline-ink">Abbrechen</a>
        </div>

    </form>
</div>
