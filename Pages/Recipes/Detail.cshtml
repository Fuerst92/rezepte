@page "{id:int}"
@model rezepte.Pages.Recipes.DetailModel
@{
    ViewData["Title"] = Model.Recipe.Title;
}

<div class="container mt-4">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Rezepte</a></li>
            <li class="breadcrumb-item active">@Model.Recipe.Title</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-4">
            @if (!string.IsNullOrEmpty(Model.Recipe.ImageUrl))
            {
                <img src="@Model.Recipe.ImageUrl" class="img-fluid rounded mb-3" alt="@Model.Recipe.Title">
            }
            else
            {
                <div class="bg-light rounded d-flex align-items-center justify-content-center mb-3"
                     style="height: 250px;">
                    <span class="text-muted fs-1">🍴</span>
                </div>
            }

            <span class="badge bg-secondary fs-6 mb-3 d-block">@Model.Recipe.Category.Name</span>
            <p class="text-muted small">Erstellt am @Model.Recipe.CreatedAt.ToString("dd.MM.yyyy")</p>

            <div class="d-grid gap-2">
                <a asp-page="/Recipes/Edit" asp-route-id="@Model.Recipe.Id"
                   class="btn btn-outline-primary">✏️ Bearbeiten</a>

                <form method="post" asp-page-handler="ToggleFavorite">
                    <input type="hidden" name="id" value="@Model.Recipe.Id" />
                    <button class="btn w-100 @(Model.Recipe.IsFavorite ? "btn-warning" : "btn-outline-warning")">
                        @(Model.Recipe.IsFavorite ? "⭐ Als Favorit gespeichert" : "☆ Als Favorit markieren")
                    </button>
                </form>

                <form method="post" asp-page-handler="Delete"
                      onsubmit="return confirm('Rezept wirklich löschen?')">
                    <input type="hidden" name="id" value="@Model.Recipe.Id" />
                    <button class="btn btn-outline-danger w-100">🗑️ Löschen</button>
                </form>
            </div>
        </div>

        <div class="col-md-8">
            <h1>@Model.Recipe.Title</h1>
            <p class="lead text-muted">@Model.Recipe.Description</p>
            <hr>

            <h4>Zutaten</h4>
            <ul class="list-group list-group-flush mb-4">
                @foreach (var ingredient in Model.Recipe.Ingredients.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                {
                    <li class="list-group-item">@ingredient.Trim()</li>
                }
            </ul>

            <h4>Zubereitung</h4>
            <ol class="list-group list-group-flush list-group-numbered mb-4">
                @foreach (var step in Model.Recipe.Steps.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                {
                    <li class="list-group-item">@step.Trim()</li>
                }
            </ol>

            @if (!string.IsNullOrEmpty(Model.Recipe.VideoUrl))
            {
                <a href="@Model.Recipe.VideoUrl" target="_blank" class="btn btn-outline-danger">
                    ▶️ Video ansehen
                </a>
            }
        </div>
    </div>
</div>
