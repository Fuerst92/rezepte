<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Meine Rezepte</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-page="/Index">🍽️ Meine Rezepte</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" asp-page="/Index">Alle Rezepte</a>
                <a class="nav-link" asp-page="/Index" asp-route-favoritesOnly="true">⭐ Favoriten</a>
                <a class="nav-link btn btn-outline-light btn-sm ms-2 px-3" asp-page="/Recipes/Create">+ Neu</a>
            </div>
        </div>
    </nav>

    <main class="pb-5">
        @RenderBody()
    </main>

    <footer class="mt-5 py-3 bg-light text-center text-muted small border-top">
        Meine Rezeptsammlung
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
